{
  "name": "ls-framework",
  "description": "Monorepo for LS Framework — tools and libraries for building AI agents and skills.",
  "version": "1.0.0",
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "compile": "lerna run compile",
    "test": "npm run compile && lerna run test --parallel",
    "coverage": "npm run compile && lerna run coverage --parallel",
    "lint": "eslint ./packages",
    "fix": "eslint --fix ./packages",
    "clean": "rimraf ./packages/**/lib && rimraf ./packages/**/coverage",
    "dependency-check": "lerna run dependency-check --parallel",
    "security-check": "node --unhandled-rejections=strict scripts/security-check.js"
  },
  "devDependencies": {
    "@colors/colors": "^1.6.0",
    "@types/jest": "^29.5.5",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "depcheck": "^1.4.6",
    "eslint": "^8.56.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-n": "^16.4.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lerna": "^8.0.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "5.3.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm test && npm run dependency-check && npm run security-check"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "rxjs": "^7.8.2"
  }
}